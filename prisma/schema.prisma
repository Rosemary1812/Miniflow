generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String               @id @default(cuid())
  email                   String               @unique
  name                    String
  posts                   Post[]
  emailVerified           Boolean              @default(false)
  image                   String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  sessions                Session[]
  accounts                Account[]
  workflows               Workflow[]
  aiProviderProfiles      AiProviderProfile[]
  defaultWorkspaceId      String?
  defaultWorkspace        Workspace?           @relation("DefaultWorkspace", fields: [defaultWorkspaceId], references: [id])
  ownedWorkspaces         Workspace[]          @relation("WorkspaceOwner")
  workspaceMemberships    WorkspaceMember[]
  workspaceInvitesCreated WorkspaceInvite[]    @relation("WorkspaceInviteCreator")
  workflowVersionsCreated WorkflowVersion[]    @relation("WorkflowVersionCreator")
  workflowPublishLogs     WorkflowPublishLog[] @relation("WorkflowPublisher")
  mcpServersCreated       McpServer[]          @relation("McpServerCreator")

  @@map("user")
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  String
  author    User    @relation(fields: [authorId], references: [id])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AiProviderProfile {
  id              String         @id @default(cuid())
  workspaceId     String
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  provider        AiProviderKind
  baseURL         String?
  encryptedApiKey String
  iv              String
  keyVersion      Int            @default(1)
  defaultModel    String?
  enabled         Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

enum AiProviderKind {
  OPENAI_COMPATIBLE
  ANTHROPIC
  GEMINI
}

model Workflow {
  id                 String           @id @default(cuid())
  workspaceId        String
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  draftVersionId     String?          @unique
  draftVersion       WorkflowVersion? @relation("WorkflowDraftVersion", fields: [draftVersionId], references: [id])
  publishedVersionId String?          @unique
  publishedVersion   WorkflowVersion? @relation("WorkflowPublishedVersion", fields: [publishedVersionId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  nodes             Node[]
  connections       Connection[]
  executions        Execution[]
  scheduledWorkflow ScheduledWorkflow?
  versions          WorkflowVersion[]  @relation("WorkflowVersions")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum NodeType {
  INITIAL
  MANUAL_TRIGGER
  HTTP_REQUEST
  GOOGLE_FORM_TRIGGER
  STRIPE_TRIGGER
  AI_TEXT
  DISCORD
  SLACK
  IF_BRANCH
  SCHEDULE_TRIGGER
  MCP_TOOL
  KNOWLEDGE_RETRIEVAL
}

enum KnowledgeDocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum KnowledgeSourceType {
  TEXT
  MARKDOWN
  PDF
}

enum EmbeddingProvider {
  OPENAI
}

enum McpTransport {
  STREAMABLE_HTTP
}

enum McpAuthType {
  NONE
  BEARER
  HEADER
}

model ScheduledWorkflow {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowId  String    @unique
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  cron        String // cron expression, e.g. "*/5 * * * *"
  timezone    String    @default("UTC")
  active      Boolean   @default(true)
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Node {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  name             String
  type             NodeType
  position         Json
  data             Json          @default("{ }")
  retryEnabled     Boolean       @default(false)
  retryMaxAttempts Int           @default(1)
  retryStrategy    RetryStrategy @default(fixed)
  retryBaseDelayMs Int           @default(1000)
  retryMaxDelayMs  Int           @default(30000)

  outputConnections Connection[] @relation("FromNode")
  inputConnections  Connection[] @relation("ToNode")

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Connection {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  fromNodeId String
  fromNode   Node   @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId   String
  toNode     Node   @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  fromOutput String @default("main")
  toInput    String @default("main")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Execution {
  id                String          @id @default(cuid())
  workspaceId       String
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowId        String
  workflow          Workflow?       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersionId String
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id])

  status     ExecutionStatus @default(RUNNING)
  error      String?         @db.Text
  errorStack String?         @db.Text

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  inngestEventId String @unique

  output Json?
  nodes  ExecutionNode[]

  @@index([workspaceId])
  @@index([workflowVersionId])
}

model Workspace {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  ownerId            String
  owner              User                @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  defaultForUsers    User[]              @relation("DefaultWorkspace")
  members            WorkspaceMember[]
  invites            WorkspaceInvite[]
  workflows          Workflow[]
  aiProviderProfiles AiProviderProfile[]
  executions         Execution[]
  scheduledWorkflows ScheduledWorkflow[]
  mcpServers         McpServer[]
  knowledgeBases     KnowledgeBase[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([ownerId])
}

model KnowledgeBase {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?             @db.Text
  documents   KnowledgeDocument[]
  chunks      KnowledgeChunk[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([workspaceId])
}

model KnowledgeDocument {
  id              String                  @id @default(cuid())
  workspaceId     String
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase           @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  title           String
  sourceType      KnowledgeSourceType     @default(TEXT)
  sourceText      String                  @db.Text
  sourceData      String?                 @db.Text
  originalName    String?
  mimeType        String?
  status          KnowledgeDocumentStatus @default(PENDING)
  error           String?                 @db.Text
  chunkCount      Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  processedAt     DateTime?
  chunks          KnowledgeChunk[]

  @@index([workspaceId])
  @@index([knowledgeBaseId])
  @@index([status])
}

model KnowledgeChunk {
  id                String                @id @default(cuid())
  workspaceId       String
  knowledgeBaseId   String
  knowledgeBase     KnowledgeBase         @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  documentId        String
  document          KnowledgeDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  index             Int
  content           String                @db.Text
  tokenCount        Int                   @default(0)
  metadata          Json?
  embedding         Unsupported("vector")
  embeddingModel    String                @default("text-embedding-3-small")
  embeddingProvider EmbeddingProvider     @default(OPENAI)
  createdAt         DateTime              @default(now())

  @@unique([documentId, index])
  @@index([workspaceId])
  @@index([knowledgeBaseId])
  @@index([documentId])
}

model McpServer {
  id              String         @id @default(cuid())
  workspaceId     String
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  transport       McpTransport   @default(STREAMABLE_HTTP)
  url             String
  authType        McpAuthType    @default(NONE)
  encryptedSecret String?
  iv              String?
  authHeaderName  String?
  enabled         Boolean        @default(true)
  lastCheckedAt   DateTime?
  lastError       String?        @db.Text
  createdBy       String
  creator         User           @relation("McpServerCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  tools           McpToolCache[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([workspaceId])
  @@index([createdBy])
}

model McpToolCache {
  id           String    @id @default(cuid())
  workspaceId  String
  mcpServerId  String
  mcpServer    McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  name         String
  description  String?   @db.Text
  inputSchema  Json?
  lastSyncedAt DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([mcpServerId, name])
  @@index([workspaceId])
  @@index([mcpServerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        WorkspaceRole
  token       String        @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdBy   String
  creator     User          @relation("WorkspaceInviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@index([workspaceId])
  @@index([email])
}

model WorkflowVersion {
  id                   String                @id @default(cuid())
  workflowId           String
  workflow             Workflow              @relation("WorkflowVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  draftForWorkflow     Workflow?             @relation("WorkflowDraftVersion")
  publishedForWorkflow Workflow?             @relation("WorkflowPublishedVersion")
  version              Int
  name                 String
  nodes                Json
  connections          Json
  status               WorkflowVersionStatus
  createdBy            String
  creator              User                  @relation("WorkflowVersionCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  executions           Execution[]
  publishLogs          WorkflowPublishLog[]

  @@unique([workflowId, version])
  @@index([status])
}

model WorkflowPublishLog {
  id                String          @id @default(cuid())
  workflowVersionId String
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  publishedBy       String
  publisher         User            @relation("WorkflowPublisher", fields: [publishedBy], references: [id], onDelete: Cascade)
  publishedAt       DateTime        @default(now())
  note              String?

  @@index([workflowVersionId])
}

model ExecutionNode {
  id                   String              @id @default(cuid())
  executionId          String
  execution            Execution           @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId               String
  nodeType             NodeType
  nodeName             String
  attempt              Int                 @default(1)
  retryCount           Int                 @default(0)
  retryEnabled         Boolean             @default(false)
  maxAttempts          Int                 @default(1)
  retryStrategy        RetryStrategy?
  baseDelayMs          Int?
  maxDelayMs           Int?
  lastError            String?             @db.Text
  nextRetryAt          DateTime?
  status               ExecutionNodeStatus
  input                Json?
  output               Json?
  error                String?             @db.Text
  errorStack           String?             @db.Text
  startedAt            DateTime?
  completedAt          DateTime?
  durationMs           Int?
  provider             String?
  model                String?
  systemPrompt         String?             @db.Text
  userPrompt           String?             @db.Text
  resolvedPrompt       String?             @db.Text
  responseText         String?             @db.Text
  tokenUsagePrompt     Int?
  tokenUsageCompletion Int?
  tokenUsageTotal      Int?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([executionId])
  @@index([nodeId])
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum WorkflowVersionStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

enum ExecutionNodeStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum RetryStrategy {
  fixed
  exponential
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("general")
  nodes       Json
  edges       Json
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
