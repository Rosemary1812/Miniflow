generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String               @id @default(cuid())
  email                   String               @unique
  name                    String
  posts                   Post[]
  emailVerified           Boolean              @default(false)
  image                   String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  sessions                Session[]
  accounts                Account[]
  workflows               Workflow[]
  credentials             Credential[]
  defaultWorkspaceId      String?
  defaultWorkspace        Workspace?           @relation("DefaultWorkspace", fields: [defaultWorkspaceId], references: [id])
  ownedWorkspaces         Workspace[]          @relation("WorkspaceOwner")
  workspaceMemberships    WorkspaceMember[]
  workspaceInvitesCreated WorkspaceInvite[]    @relation("WorkspaceInviteCreator")
  workflowVersionsCreated WorkflowVersion[]    @relation("WorkflowVersionCreator")
  workflowPublishLogs     WorkflowPublishLog[] @relation("WorkflowPublisher")

  @@map("user")
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  String
  author    User    @relation(fields: [authorId], references: [id])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Credential {
  id             String         @id @default(cuid())
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  encryptedValue String // AES-256-GCM encrypted API key
  iv             String // Initialization vector (16 bytes hex)
  keyVersion     Int            @default(1) // Encryption key version for rotation
  type           CredentialType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  Node Node[]

  // Hide plaintext value from Prisma queries by default
  @@index([workspaceId])
  @@map("credential")
}

enum CredentialType {
  OPENAI
  ANTHROPIC
  GEMINI
}

model Workflow {
  id                 String           @id @default(cuid())
  workspaceId        String
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  draftVersionId     String?          @unique
  draftVersion       WorkflowVersion? @relation("WorkflowDraftVersion", fields: [draftVersionId], references: [id])
  publishedVersionId String?          @unique
  publishedVersion   WorkflowVersion? @relation("WorkflowPublishedVersion", fields: [publishedVersionId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  nodes             Node[]
  connections       Connection[]
  executions        Execution[]
  scheduledWorkflow ScheduledWorkflow?
  versions          WorkflowVersion[]  @relation("WorkflowVersions")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum NodeType {
  INITIAL
  MANUAL_TRIGGER
  HTTP_REQUEST
  GOOGLE_FORM_TRIGGER
  STRIPE_TRIGGER
  ANTHROPIC
  GEMINI
  OPENAI
  DISCORD
  SLACK
  IF_BRANCH
  SCHEDULE_TRIGGER
}

model ScheduledWorkflow {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowId  String    @unique
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  cron        String // cron expression, e.g. "*/5 * * * *"
  timezone    String    @default("UTC")
  active      Boolean   @default(true)
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Node {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  name             String
  type             NodeType
  position         Json
  data             Json          @default("{ }")
  retryEnabled     Boolean       @default(false)
  retryMaxAttempts Int           @default(1)
  retryStrategy    RetryStrategy @default(fixed)
  retryBaseDelayMs Int           @default(1000)
  retryMaxDelayMs  Int           @default(30000)

  outputConnections Connection[] @relation("FromNode")
  inputConnections  Connection[] @relation("ToNode")

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  credential   Credential? @relation(fields: [credentialId], references: [id])
  credentialId String?
}

model Connection {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  fromNodeId String
  fromNode   Node   @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId   String
  toNode     Node   @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  fromOutput String @default("main")
  toInput    String @default("main")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Execution {
  id                String          @id @default(cuid())
  workspaceId       String
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowId        String
  workflow          Workflow?       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersionId String
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id])

  status     ExecutionStatus @default(RUNNING)
  error      String?         @db.Text
  errorStack String?         @db.Text

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  inngestEventId String @unique

  output Json?
  nodes  ExecutionNode[]

  @@index([workspaceId])
  @@index([workflowVersionId])
}

model Workspace {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  ownerId            String
  owner              User                @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  defaultForUsers    User[]              @relation("DefaultWorkspace")
  members            WorkspaceMember[]
  invites            WorkspaceInvite[]
  workflows          Workflow[]
  credentials        Credential[]
  executions         Execution[]
  scheduledWorkflows ScheduledWorkflow[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        WorkspaceRole
  token       String        @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdBy   String
  creator     User          @relation("WorkspaceInviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@index([workspaceId])
  @@index([email])
}

model WorkflowVersion {
  id                   String                @id @default(cuid())
  workflowId           String
  workflow             Workflow              @relation("WorkflowVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  draftForWorkflow     Workflow?             @relation("WorkflowDraftVersion")
  publishedForWorkflow Workflow?             @relation("WorkflowPublishedVersion")
  version              Int
  name                 String
  nodes                Json
  connections          Json
  status               WorkflowVersionStatus
  createdBy            String
  creator              User                  @relation("WorkflowVersionCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  executions           Execution[]
  publishLogs          WorkflowPublishLog[]

  @@unique([workflowId, version])
  @@index([status])
}

model WorkflowPublishLog {
  id                String          @id @default(cuid())
  workflowVersionId String
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  publishedBy       String
  publisher         User            @relation("WorkflowPublisher", fields: [publishedBy], references: [id], onDelete: Cascade)
  publishedAt       DateTime        @default(now())
  note              String?

  @@index([workflowVersionId])
}

model ExecutionNode {
  id                   String              @id @default(cuid())
  executionId          String
  execution            Execution           @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId               String
  nodeType             NodeType
  nodeName             String
  attempt              Int                 @default(1)
  retryCount           Int                 @default(0)
  retryEnabled         Boolean             @default(false)
  maxAttempts          Int                 @default(1)
  retryStrategy        RetryStrategy?
  baseDelayMs          Int?
  maxDelayMs           Int?
  lastError            String?             @db.Text
  nextRetryAt          DateTime?
  status               ExecutionNodeStatus
  input                Json?
  output               Json?
  error                String?             @db.Text
  errorStack           String?             @db.Text
  startedAt            DateTime?
  completedAt          DateTime?
  durationMs           Int?
  provider             String?
  model                String?
  systemPrompt         String?             @db.Text
  userPrompt           String?             @db.Text
  resolvedPrompt       String?             @db.Text
  responseText         String?             @db.Text
  tokenUsagePrompt     Int?
  tokenUsageCompletion Int?
  tokenUsageTotal      Int?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([executionId])
  @@index([nodeId])
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum WorkflowVersionStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

enum ExecutionNodeStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum RetryStrategy {
  fixed
  exponential
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("general")
  nodes       Json
  edges       Json
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
