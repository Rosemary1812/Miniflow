# Environment variables — copy to .env and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/miniflow"

# Better Auth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# AI Providers (at least one required)
GOOGLE_GENERATIVE_AI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

# Sentry (optional, for error monitoring)
# Get your token from: https://sentry.io
SENTRY_AUTH_TOKEN=""

# Polar (optional, for subscription management)
# Get your token from: https://polar.sh
POLAR_ACCESS_TOKEN=""
POLAR_SUCCESS_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Credential Encryption (REQUIRED)
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=""

# Ngrok (optional, for webhook testing in dev)
NGROK_URL=""
